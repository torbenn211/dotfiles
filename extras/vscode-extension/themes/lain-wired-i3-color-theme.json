{
  "$schema": "vscode://schemas/color-theme",
  "name": "Lain Wired i3",
  "type": "dark",
  "colors": {
    "focusBorder": "#6f9ed0",
    "foreground": "#c8c2aa",
    "descriptionForeground": "#716b5d",
    "errorForeground": "#d1624f",
    "selection.background": "#0d1722",
    "textLink.foreground": "#6f9ed0",
    "textLink.activeForeground": "#8fb6dd",
    "textPreformat.foreground": "#76b7a8",
    "button.background": "#0d1722",
    "button.foreground": "#8fb6dd",
    "button.hoverBackground": "#142235",
    "dropdown.background": "#030403",
    "dropdown.border": "#343832",
    "dropdown.foreground": "#c8c2aa",
    "input.background": "#030403",
    "input.border": "#343832",
    "input.foreground": "#c8c2aa",
    "inputOption.activeBorder": "#6f9ed0",
    "inputValidation.errorBorder": "#c94f37",
    "badge.background": "#0d1722",
    "badge.foreground": "#8fb6dd",
    "progressBar.background": "#c94f37",
    "list.activeSelectionBackground": "#0d1722",
    "list.activeSelectionForeground": "#8fb6dd",
    "list.focusBackground": "#090a08",
    "list.hoverBackground": "#090a08",
    "list.inactiveSelectionBackground": "#090a08",
    "activityBar.background": "#030403",
    "activityBar.foreground": "#8fb6dd",
    "activityBar.inactiveForeground": "#625f55",
    "activityBarBadge.background": "#c94f37",
    "activityBarBadge.foreground": "#030403",
    "sideBar.background": "#030403",
    "sideBar.foreground": "#c8c2aa",
    "sideBar.border": "#090a08",
    "sideBarTitle.foreground": "#8fb6dd",
    "sideBarSectionHeader.background": "#090a08",
    "sideBarSectionHeader.foreground": "#e7dec8",
    "editorGroupHeader.tabsBackground": "#030403",
    "editorGroup.border": "#090a08",
    "tab.activeBackground": "#030403",
    "tab.activeForeground": "#8fb6dd",
    "tab.activeBorderTop": "#6f9ed0",
    "tab.inactiveBackground": "#090a08",
    "tab.inactiveForeground": "#716b5d",
    "tab.border": "#030403",
    "editor.background": "#030403",
    "editor.foreground": "#c8c2aa",
    "editorLineNumber.foreground": "#343832",
    "editorLineNumber.activeForeground": "#8fb6dd",
    "editorCursor.foreground": "#e7dec8",
    "editor.selectionBackground": "#0d1722",
    "editor.inactiveSelectionBackground": "#121a22",
    "editor.lineHighlightBackground": "#090a08",
    "editor.lineHighlightBorder": "#090a08",
    "editorIndentGuide.background1": "#090a08",
    "editorIndentGuide.activeBackground1": "#343832",
    "editorWhitespace.foreground": "#2a2c27",
    "editorRuler.foreground": "#090a08",
    "editorWidget.background": "#030403",
    "editorWidget.border": "#343832",
    "editorSuggestWidget.background": "#030403",
    "editorSuggestWidget.border": "#343832",
    "editorSuggestWidget.foreground": "#c8c2aa",
    "editorSuggestWidget.selectedBackground": "#0d1722",
    "editorHoverWidget.background": "#030403",
    "editorHoverWidget.border": "#343832",
    "peekView.border": "#6f9ed0",
    "peekViewEditor.background": "#030403",
    "peekViewResult.background": "#030403",
    "peekViewResult.selectionBackground": "#0d1722",
    "panel.background": "#030403",
    "panel.border": "#090a08",
    "panelTitle.activeBorder": "#6f9ed0",
    "panelTitle.activeForeground": "#8fb6dd",
    "statusBar.background": "#0d1722",
    "statusBar.foreground": "#8fb6dd",
    "statusBar.noFolderBackground": "#090a08",
    "statusBar.debuggingBackground": "#c94f37",
    "statusBar.debuggingForeground": "#030403",
    "terminal.background": "#030403",
    "terminal.foreground": "#c8c2aa",
    "terminalCursor.foreground": "#e7dec8",
    "terminal.ansiBlack": "#090a08",
    "terminal.ansiRed": "#c94f37",
    "terminal.ansiGreen": "#8ba36f",
    "terminal.ansiYellow": "#d0a85a",
    "terminal.ansiBlue": "#6f9ed0",
    "terminal.ansiMagenta": "#b58ad6",
    "terminal.ansiCyan": "#76b7a8",
    "terminal.ansiWhite": "#c8c2aa",
    "terminal.ansiBrightBlack": "#343832",
    "terminal.ansiBrightRed": "#d1624f",
    "terminal.ansiBrightGreen": "#a6b98a",
    "terminal.ansiBrightYellow": "#e6c06f",
    "terminal.ansiBrightBlue": "#8fb6dd",
    "terminal.ansiBrightMagenta": "#c79ee6",
    "terminal.ansiBrightCyan": "#9bd8ca",
    "terminal.ansiBrightWhite": "#e7dec8",
    "titleBar.activeBackground": "#030403",
    "titleBar.activeForeground": "#8fb6dd",
    "titleBar.inactiveBackground": "#030403",
    "titleBar.inactiveForeground": "#625f55",
    "menu.background": "#030403",
    "menu.foreground": "#c8c2aa",
    "menu.selectionBackground": "#0d1722",
    "menu.selectionForeground": "#8fb6dd"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#343832", "fontStyle": "italic" }
    },
    {
      "scope": ["keyword", "storage", "modifier"],
      "settings": { "foreground": "#c94f37", "fontStyle": "bold" }
    },
    {
      "scope": ["string", "markup.inline.raw"],
      "settings": { "foreground": "#8ba36f" }
    },
    {
      "scope": ["constant.numeric", "constant.language", "support.constant"],
      "settings": { "foreground": "#d0a85a" }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": { "foreground": "#6f9ed0" }
    },
    {
      "scope": ["entity.name.type", "support.type", "storage.type"],
      "settings": { "foreground": "#e6c06f" }
    },
    {
      "scope": ["variable", "meta.definition.variable.name"],
      "settings": { "foreground": "#c8c2aa" }
    },
    {
      "scope": ["variable.parameter", "entity.other.attribute-name"],
      "settings": { "foreground": "#b58ad6" }
    },
    {
      "scope": ["punctuation", "meta.brace"],
      "settings": { "foreground": "#716b5d" }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#e7dec8", "background": "#241815" }
    }
  ]
}
